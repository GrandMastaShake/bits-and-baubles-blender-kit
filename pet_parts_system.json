{
  "_meta": {
    "name": "Bits and Baubles — Modular Pet Parts System",
    "version": "1.0.0",
    "description": "Mix-and-match pet part library for procedural creature generation. Compatible with Adopt Me-style low-poly pets.",
    "format": "Each part defines geometry, attachment points, and compatible species.",
    "units": "Blender units (1 stud = 0.008)",
    "author": "Centuria Forge Swarm"
  },

  "part_categories": {
    "head": {
      "description": "Head shapes — determines species family",
      "attachment": "connects_to: neck",
      "slot": "single"
    },
    "ears": {
      "description": "Ear styles — floppy, pointy, round",
      "attachment": "connects_to: head.sides",
      "slot": "pair"
    },
    "eyes": {
      "description": "Eye styles — determines expression",
      "attachment": "connects_to: head.front",
      "slot": "pair"
    },
    "snout": {
      "description": "Snout/muzzle — determines eating animation",
      "attachment": "connects_to: head.front_bottom",
      "slot": "single"
    },
    "body": {
      "description": "Body shape — determines size class",
      "attachment": "connects_to: root",
      "slot": "single"
    },
    "legs": {
      "description": "Leg styles — walk/run animation",
      "attachment": "connects_to: body.bottom",
      "slot": "quad"
    },
    "tail": {
      "description": "Tail styles — wag/emote animation",
      "attachment": "connects_to: body.rear",
      "slot": "single"
    },
    "wings": {
      "description": "Wing styles — for flying pets",
      "attachment": "connects_to: body.top",
      "slot": "pair"
    },
    "horns": {
      "description": "Horn/antler styles — decorative",
      "attachment": "connects_to: head.top",
      "slot": "pair_or_single"
    },
    "pattern": {
      "description": "Color pattern — stripes, spots, solid",
      "attachment": "applies_to: all",
      "slot": "overlay"
    }
  },

